{
    "name": "@mat3ra/workflow-designer-tests",
    "version": "0.0.0",
    "description": "Cypress E2E tests for @mat3ra/workflow-designer standalone app",
    "main": "index.js",
    "scripts": {
        "test": "CYPRESS_BASE_URL=${CYPRESS_BASE_URL:-'http://localhost:3001'} cypress open",
        "test:headless": "CYPRESS_BASE_URL=${CYPRESS_BASE_URL:-'http://localhost:3001'} cypress run --e2e",
        "lint": "npx eslint cypress && prettier --write cypress"
    },
    "engines": {
        "npm": ">=10.0.0",
        "node": ">=18.0.0"
    },
    "author": "",
    "license": "Apache-2.0",
    "dependencies": {
        "@badeball/cypress-cucumber-preprocessor": "^20.0.0",
        "@bahmutov/cypress-esbuild-preprocessor": "^2.2.0",
        "@types/node": "^20.10.1",
        "cypress": "^13.6.0",
        "typescript": "^5.3.2"
    },
    "devDependencies": {
        "prettier": "2.5.1"
    },
    "cypress-cucumber-preprocessor": {
        "nonGlobalStepDefinitions": false,
        "stepDefinitions": "cypress/e2e/step_definitions/**/*.{ts,js}"
    }
}
