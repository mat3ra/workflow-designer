    },
    "bugs": {
        "url": "https://github.com/mat3ra/workflow-designer/issues"
    },
    "homepage": "https://github.com/mat3ra/workflow-designer",
    "main": "dist/exports.js",
    "types": "dist/exports.d.ts",
