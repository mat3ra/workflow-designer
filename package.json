        "/dist",
        "/src",
        "tsconfig.json"
    ],
    "scripts": {
        "build": "tsc && npm run copy-css",
        "copy-css": "mkdir -p dist/stylesheets && cp src/stylesheets/* dist/stylesheets/ 2>/dev/null || true",
        "transpile": "tsc",
        "test": "node --import tsx --test tests/*.tests.ts",
        "lint": "eslint src tests && prettier --check src tests",
        "dev": "vite --port 3002",
        "test:e2e": "cd tests/e2e && npm run test:headless"
    },
    "dependencies": {
